      "name": "Validation",
      "description": "Tests that Shimmy rejects malformed requests that fail JSON schema validation.",
      "item": [
        {
          "name": "18 – Missing/null answer field",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"response\": \"print(1)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}", "host": ["{{baseUrl}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Request is rejected (400 or error body)', () => {",
                  "    const status = pm.response.code;",
                  "    const json   = pm.response.json();",
                  "    const isErrorStatus = status === 400 || status === 422;",
                  "    const hasErrorBody  = json.hasOwnProperty('error');",
                  "    pm.expect(isErrorStatus || hasErrorBody,",
                  "        'Expected HTTP 4xx or an error field in the body'",
                  "    ).to.be.true;",
                  "});"
                ]
              }
            }
          ]
